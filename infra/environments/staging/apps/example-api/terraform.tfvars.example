# terraform.tfvars — non-secret, environment-scoped variable values.
#
# This file is a reference template. The real terraform.tfvars is gitignored
# and generated by running:
#
#   make infra-generate-backend-configs
#
# That script derives github_org from the repository's git remote automatically.
# Do not hand-edit or commit terraform.tfvars.

github_org = "<GITHUB_ORG>"

# URI of the bootstrap image used only for the initial Lambda creation.
# Lambda requires an image from a private ECR repository in this account —
# public ECR URIs are not accepted. Push a placeholder image to the ECR repo
# first, then set this to the resulting private ECR URI.
# See apps/example-api/docs/infrastructure.md — Step 4 for the
# exact commands.
lambda_bootstrap_image_uri = "<ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/example-monorepo-example-api:bootstrap"
