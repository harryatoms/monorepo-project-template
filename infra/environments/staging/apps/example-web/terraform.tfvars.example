# terraform.tfvars — non-secret, environment-scoped variable values.
#
# This file is a reference template. The real terraform.tfvars is gitignored
# and generated by running:
#
#   make infra-generate-backend-configs
#
# That script derives github_org from the repository's git remote automatically.
# Do not hand-edit or commit terraform.tfvars.

github_org = "<GITHUB_ORG>"
