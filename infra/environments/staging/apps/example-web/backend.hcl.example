# backend.hcl — Terraform S3 backend configuration for staging/apps/example-web
#
# This file is a reference template. The real backend.hcl is gitignored
# and generated by running:
#
#   make infra-generate-backend-configs
#
# That script resolves your AWS account ID and writes the correct bucket
# name automatically. Do not hand-edit or commit backend.hcl.

bucket         = "example-monorepo-tfstate-<AWS_ACCOUNT_ID>"
key            = "environments/staging/apps/example-web/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "example-monorepo-terraform-locks"
encrypt        = true
