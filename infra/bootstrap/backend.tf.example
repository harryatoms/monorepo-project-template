# backend.tf — Terraform S3 backend configuration for infra/bootstrap
#
# This file is a reference template. The real backend.tf is gitignored
# and generated by running:
#
#   make infra-generate-backend-configs
#
# When backend.tf exists, Terraform uses the S3 backend.
# When it does not exist, Terraform uses local state (first-time and teardown flows).
# See docs/operations/account-setup.md for the full lifecycle.

terraform {
  backend "s3" {
    bucket         = "example-monorepo-tfstate-<AWS_ACCOUNT_ID>"
    key            = "bootstrap/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "example-monorepo-terraform-locks"
    encrypt        = true
  }
}
