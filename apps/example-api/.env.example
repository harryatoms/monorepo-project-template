# Runtime context
SERVICE_NAME=example-api
ENVIRONMENT=local
VERSION=local

# Server
PORT=8000
CORS_ALLOW_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=auto

# Optional LLM provider. The default boilerplate app does not require secrets.
LLM_PROVIDER=disabled
LLM_MODEL=gpt-4.1-mini
LLM_PROMPT_CALL=example
# OPENAI_API_KEY=
# SSM_OPENAI_API_KEY_PATH=
OPENAI_TIMEOUT_SECONDS=25
OPENAI_MAX_RETRIES=1
