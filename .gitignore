# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
.ruff_cache/

# Env files
.env
.env.*
!.env.example

# macOS
.DS_Store
__MACOSX/
._*

# Editor / IDE
.vscode/
.idea/

# Cursor / AI tooling
.cursor/cache/
.cursor/workspaceStorage/
.claude/settings.local.json

# Evals
evals/results/

# Terraform
**/.terraform/
infra/.plans/
**/terraform.tfstate
**/terraform.tfstate.backup
# backend.hcl and terraform.tfvars are generated per-machine by
# scripts/generate-backend-configs.sh. See the corresponding *.example files
# in each directory for the expected format.
**/backend.hcl
!**/backend.hcl.example
**/terraform.tfvars
!**/terraform.tfvars.example
# bootstrap/backend.tf is generated by generate-backend-configs.sh.
# Its presence switches bootstrap from local to S3 state. Delete to revert to local.
infra/bootstrap/backend.tf
!infra/bootstrap/backend.tf.example

# Misc
dist/
build/